{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/relationships/relationship.schema.json",
  "title": "Relationship",
  "description": "علاقة عامة",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "kind": {
      "type": "string",
      "description": "نوع"
    },
    "from_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "to_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "id",
    "from_id",
    "to_id"
  ],
  "additionalProperties": false
}
