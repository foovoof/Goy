{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/relationships/communication.schema.json",
  "title": "Communication",
  "description": "اتصال",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "from_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "to_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "channel": {
      "type": "string",
      "enum": [
        "email",
        "sms",
        "voice",
        "chat",
        "social",
        "postal"
      ]
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "content_ref": {
      "type": "string",
      "description": "مرجع محتوى"
    }
  },
  "required": [
    "id",
    "from_id",
    "to_id"
  ],
  "additionalProperties": false
}
