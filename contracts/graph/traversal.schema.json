{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/graph/traversal.schema.json",
  "title": "GraphTraversal",
  "description": "اجتياز",
  "type": "object",
  "properties": {
    "strategy": {
      "type": "string",
      "enum": [
        "bfs",
        "dfs",
        "dijkstra",
        "astar"
      ]
    },
    "start": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "goal": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "max_nodes": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": [
    "strategy",
    "start"
  ],
  "additionalProperties": false
}
