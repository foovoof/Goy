{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/domain/relationship.schema.json",
  "title": "Relationship",
  "description": "علاقة بين كيانين",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "from_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "to_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "kind": {
      "type": "string",
      "enum": [
        "knows",
        "owns",
        "works_at",
        "located_at",
        "communicated_with",
        "transacted_with",
        "related_to"
      ]
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false
}
