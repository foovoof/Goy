{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/domain/identity.schema.json",
  "title": "Identity",
  "description": "هوية شخص/كيان",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "display_name": {
      "type": "string",
      "description": "الاسم المعروض"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verified": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false
}
