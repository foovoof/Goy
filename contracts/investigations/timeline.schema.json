{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/domain/timeline.schema.json",
  "title": "Timeline",
  "description": "خط زمني",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "https://foovoof.github.io/Goy/contracts/domain/event.schema.json"
      }
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false
}
