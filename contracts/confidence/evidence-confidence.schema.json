{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/confidence/evidence-confidence.schema.json",
  "title": "EvidenceConfidence",
  "description": "درجة ثقة دليل",
  "type": "object",
  "properties": {
    "evidence_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reliability": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D",
        "E",
        "F"
      ]
    }
  },
  "required": [
    "evidence_id",
    "score"
  ],
  "additionalProperties": false
}
