{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/relationships/transaction.schema.json",
  "title": "Transaction",
  "description": "معاملة",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "from_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "to_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "description": "عملة"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "reference": {
      "type": "string",
      "description": "مرجع"
    }
  },
  "required": [
    "id",
    "from_id",
    "to_id"
  ],
  "additionalProperties": false
}
