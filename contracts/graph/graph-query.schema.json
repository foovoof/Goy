{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/graph/graph-query.schema.json",
  "title": "GraphQuery",
  "description": "استعلام رسم بياني",
  "type": "object",
  "properties": {
    "start": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "max_depth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 3
    },
    "edge_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "start"
  ],
  "additionalProperties": false
}
