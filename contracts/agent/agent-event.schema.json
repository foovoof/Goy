{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/agent/agent-event.schema.json",
  "title": "AgentEvent",
  "description": "حدث صادر عن وكيل",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "type": {
      "type": "string",
      "enum": [
        "started",
        "progress",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "agent_id",
    "type",
    "occurred_at"
  ],
  "additionalProperties": false
}
