{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/orchestration/workflow-state.schema.json",
  "title": "WorkflowState",
  "description": "حالة سير عمل",
  "type": "object",
  "properties": {
    "execution_id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "current_step": {
      "type": "string",
      "description": "خطوة حالية"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "execution_id",
    "status"
  ],
  "additionalProperties": false
}
