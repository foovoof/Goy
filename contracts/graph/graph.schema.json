{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/graph/graph.schema.json",
  "title": "Graph",
  "description": "رسم بياني كامل",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "https://foovoof.github.io/Goy/contracts/graph/node.schema.json"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "https://foovoof.github.io/Goy/contracts/graph/edge.schema.json"
      }
    }
  },
  "required": [
    "id",
    "nodes",
    "edges"
  ],
  "additionalProperties": false
}
