{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/graph/inference.schema.json",
  "title": "GraphInference",
  "description": "استنتاج من الرسم",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "rule": {
      "type": "string",
      "description": "قاعدة"
    },
    "produced_edges": {
      "type": "array",
      "items": {
        "$ref": "https://foovoof.github.io/Goy/contracts/graph/edge.schema.json"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": [
    "id",
    "rule"
  ],
  "additionalProperties": false
}
