{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/provenance/lineage.schema.json",
  "title": "Lineage",
  "description": "سلالة اشتقاق",
  "type": "object",
  "properties": {
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "at",
          "operation"
        ],
        "properties": {
          "at": {
            "type": "string",
            "format": "date-time"
          },
          "operation": {
            "type": "string",
            "description": "عملية"
          },
          "input_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "output_id": {
            "type": "string",
            "description": "خرج"
          }
        }
      }
    }
  },
  "required": [
    "steps"
  ],
  "additionalProperties": false
}
