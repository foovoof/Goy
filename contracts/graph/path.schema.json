{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/graph/path.schema.json",
  "title": "GraphPath",
  "description": "مسار في الرسم",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "length": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": [
    "nodes",
    "edges"
  ],
  "additionalProperties": false
}
