{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/entities/person.schema.json",
  "title": "Person",
  "description": "شخص",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "full_name": {
      "type": "string",
      "description": "الاسم الكامل"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "date_of_birth": {
      "type": "string",
      "format": "date"
    },
    "nationality": {
      "type": "string",
      "description": "الجنسية"
    },
    "gender": {
      "type": "string",
      "enum": [
        "male",
        "female",
        "unspecified"
      ]
    }
  },
  "required": [
    "id"
  ],
  "additionalProperties": false
}
