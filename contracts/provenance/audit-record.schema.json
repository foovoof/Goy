    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "actor": {
      "type": "string",
      "description": "منفذ"
    },
    "action": {
      "type": "string",
      "description": "إجراء"
    },
    "target": {
      "type": "string",
      "description": "هدف"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
