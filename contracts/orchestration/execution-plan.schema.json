{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/orchestration/execution-plan.schema.json",
  "title": "ExecutionPlan",
  "description": "خطة تنفيذ",
  "type": "object",
  "properties": {
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "action"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "id"
          },
          "action": {
            "type": "string",
            "description": "action"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "required": [
    "steps"
  ],
  "additionalProperties": false
}
