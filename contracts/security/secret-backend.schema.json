{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/security/secret-backend.schema.json",
  "title": "SecretBackend",
  "description": "مخزن أسرار",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "kind": {
      "type": "string",
      "enum": [
        "env",
        "vault",
        "aws_sm",
        "gcp_sm",
        "azure_kv",
        "file"
      ]
    },
    "config": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "id",
    "kind"
  ],
  "additionalProperties": false
}
