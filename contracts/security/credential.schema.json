{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/security/credential.schema.json",
  "title": "Credential",
  "description": "اعتماد وصول",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "معرف فريد"
    },
    "kind": {
      "type": "string",
      "enum": [
        "api_key",
        "oauth_token",
        "username_password",
        "certificate"
      ]
    },
    "reference": {
      "$ref": "https://foovoof.github.io/Goy/contracts/security/secret-reference.schema.json"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "kind",
    "reference"
  ],
  "additionalProperties": false
}
