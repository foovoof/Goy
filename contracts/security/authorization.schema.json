{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foovoof.github.io/Goy/contracts/security/authorization.schema.json",
  "title": "Authorization",
  "description": "نتيجة قرار تفويض",
  "type": "object",
  "properties": {
    "subject": {
      "type": "string",
      "description": "مستخدم"
    },
    "resource": {
      "type": "string",
      "description": "مورد"
    },
    "action": {
      "type": "string",
      "description": "فعل"
    },
    "allowed": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "description": "سبب"
    }
  },
  "required": [
    "subject",
    "resource",
    "action",
    "allowed"
  ],
  "additionalProperties": false
}
